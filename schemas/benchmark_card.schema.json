{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://openamp-foundry.org/schemas/benchmark_card.schema.json",
    "title": "BenchmarkCard",
    "description": "Schema for a benchmark card — a machine-readable artifact describing what was benchmarked, what the baseline was, what the result was, and what claims are supported. Dry-lab only — does not measure biological activity.",
    "type": "object",
    "properties": {
        "benchmark_id": {
            "description": "Unique identifier for the benchmark",
            "type": "string",
            "minLength": 1
        },
        "benchmark_name": {
            "description": "Human-readable benchmark name",
            "type": "string",
            "minLength": 1
        },
        "version": {
            "description": "Schema version (MAJOR.MINOR.PATCH)",
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "date": {
            "description": "Date the benchmark was run (YYYY-MM-DD)",
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "metric": {
            "description": "Metric name (e.g. AUROC, AUPRC, recall@k)",
            "type": "string",
            "minLength": 1
        },
        "metric_value": {
            "description": "Observed metric value",
            "type": "number"
        },
        "baseline_name": {
            "description": "Name of the comparison baseline",
            "type": "string",
            "minLength": 1
        },
        "baseline_value": {
            "description": "Baseline metric value",
            "type": "number"
        },
        "delta": {
            "description": "metric_value - baseline_value",
            "type": "number"
        },
        "beats_baseline": {
            "description": "True if metric_value > baseline_value",
            "type": "boolean"
        },
        "dataset": {
            "description": "Name or identifier of the dataset used",
            "type": "string",
            "minLength": 1
        },
        "dataset_size": {
            "description": "Number of samples in the dataset",
            "type": "integer",
            "minimum": 1
        },
        "scope": {
            "description": "List of biological scopes this benchmark applies to",
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
        },
        "caveats": {
            "description": "List of caveats and limitations",
            "type": "array",
            "items": { "type": "string" }
        },
        "dry_lab_only": {
            "description": "Must be true — benchmark cards are computational artifacts, not biological proof",
            "type": "boolean",
            "const": true
        }
    },
    "required": [
        "benchmark_id",
        "benchmark_name",
        "version",
        "date",
        "metric",
        "metric_value",
        "baseline_name",
        "baseline_value",
        "delta",
        "beats_baseline",
        "dataset",
        "dataset_size",
        "scope",
        "caveats",
        "dry_lab_only"
    ],
    "additionalProperties": false
}
