{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://openamp.ai/schemas/simulation_result.schema.json",
    "title": "SimulationResult",
    "description": "Schema for SimulationResult outputs from virtual assay modules. Dry-lab only — does not measure biological activity.",
    "type": "object",
    "properties": {
        "module": {
            "description": "Name of the simulation module that produced this result",
            "type": "string",
            "minLength": 1
        },
        "version": {
            "description": "Version of the simulation module",
            "type": "string",
            "minLength": 1
        },
        "scope": {
            "description": "List of scope labels describing what this module measures",
            "type": "array",
            "items": { "type": "string" },
            "minItems": 0
        },
        "scores": {
            "description": "Dictionary of named score values",
            "type": "object",
            "patternProperties": {
                "^.*$": { "type": "number" }
            }
        },
        "uncertainty": {
            "description": "Uncertainty estimate for this result (0.0 = fully certain, 1.0 = fully uncertain)",
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
        },
        "calibration_set": {
            "description": "Optional identifier for the calibration dataset used",
            "type": ["string", "null"]
        },
        "validated_against": {
            "description": "List of reference datasets or benchmarks this module was validated against",
            "type": "array",
            "items": { "type": "string" }
        },
        "notes": {
            "description": "Free-text notes about this result",
            "type": "array",
            "items": { "type": "string" }
        },
        "dry_lab_context": {
            "description": "Marks this result as dry-lab only",
            "type": "string",
            "const": "dry-lab-only"
        }
    },
    "required": [
        "module",
        "version",
        "scope",
        "scores",
        "uncertainty",
        "calibration_set",
        "validated_against",
        "notes"
    ],
    "additionalProperties": false
}
