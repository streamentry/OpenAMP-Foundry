{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenAMP Candidate Evidence Certificate",
  "type": "object",
  "required": [
    "candidate_id",
    "sequence",
    "features",
    "scores",
    "selection_reason",
    "known_failure_modes",
    "recommended_next_steps",
    "generated_at",
    "pipeline_version"
  ],
  "properties": {
    "candidate_id": {"type": "string"},
    "sequence": {"type": "string"},
    "source": {"type": "string", "description": "Dataset or generator that produced this candidate."},
    "features": {"type": "object"},
    "nearest_reference": {
      "description": "Closest known reference AMP found during novelty check, or null if none found.",
      "oneOf": [{"type": "object"}, {"type": "null"}]
    },
    "scores": {
      "type": "object",
      "required": ["activity", "safety", "synthesis", "novelty", "ensemble"],
      "properties": {
        "activity": {"type": "number", "minimum": 0, "maximum": 1},
        "safety": {"type": "number", "minimum": 0, "maximum": 1},
        "synthesis": {"type": "number", "minimum": 0, "maximum": 1},
        "novelty": {"type": "number", "minimum": 0, "maximum": 1},
        "ensemble": {"type": "number", "minimum": 0, "maximum": 1},
        "boman_activity": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Boman index (2003) normalized to [0,1]. Independent second activity scorer."
        },
        "disagreement": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Absolute difference between activity_likeness and boman_activity. High values indicate scoring uncertainty."
        },
        "sim_membrane_uncertainty": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Experimental membrane-proxy uncertainty. Informational only unless weighted simulation is explicitly allowed."
        },
        "sim_structure_uncertainty": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Experimental structure-proxy uncertainty. Informational only unless weighted simulation is explicitly allowed."
        },
        "sim_max_uncertainty": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Maximum virtual-assay proxy uncertainty for this candidate. Values above 0.5 must not affect selection."
        }
      }
    },
    "references_checked": {"type": "array", "items": {"type": "string"}},
    "selection_reason": {"type": "array", "items": {"type": "string"}},
    "known_failure_modes": {"type": "array", "items": {"type": "string"}},
    "recommended_next_steps": {"type": "array", "items": {"type": "string"}},
    "generated_at": {"type": "string"},
    "pipeline_version": {"type": "string"},
    "config_hash": {"type": "string"},
    "proof_ladder_level": {
      "type": "string",
      "enum": [
        "valid_input",
        "reproducible_dry_lab_features",
        "baseline_triaged",
        "leakage_aware_benchmark",
        "multi_signal_candidate_evidence",
        "expert_reviewed_assay_proposal",
        "initial_qualified_assay_result",
        "safety_adjusted_follow_up_signal",
        "independent_replication",
        "reusable_discovery_loop",
        "translational_or_clinical_relevance"
      ],
      "description": "Highest proof-ladder level this candidate's evidence supports. See docs/evidence/PROOF_LADDER.md."
    }
  }
}
